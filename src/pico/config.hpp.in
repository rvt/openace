#define LWIP_TCPIP_CORE_LOCKING_INPUT 1

// START: The following is needed to test mDns
#define LWIP_MDNS_RESPONDER 1
#define LWIP_IGMP 1
#define LWIP_NUM_NETIF_CLIENT_DATA 1
