#define CYW43_DEFAULT_IP_STA_ADDRESS LWIP_MAKEU32(192, 168, 1, 1)
#define CYW43_DEFAULT_IP_STA_GATEWAY LWIP_MAKEU32(192, 168, 1, 1)
