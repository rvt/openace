// Route UART messages over different pins by default
#if GATAS_UART_OVER_USB
    #define PICO_DEFAULT_UART 1
#else
    #define PICO_DEFAULT_UART_RX_PIN  17
    #define PICO_DEFAULT_UART_TX_PIN  16
#endif

// DHCP lease time. 30 minutes TO ensure we remove unneeded targets on time. But long enough to ensure we do not loose connection
#define GATAS_DEFAULT_LEASE_TIME_S ( 60 * 30 )

// ***** ETLCPP 
// https://www.etlcpp.com/mutex.html
// Malloc in ETL should use FreeRTOS mutexes
#define ETL_TARGET_OS_FREERTOS ( 1 )
#define ETL_STRING_TRUNCATION_IS_ERROR ( 1 ) 
#define ETL_NO_EXCEPTIONS ( 1 ) // Disable exceptions
#define ETL_USING_CPP11 ( 1 )
// TODO: Re-enable so we can use etl::delegate and get rid of std
// #define ETL_NO_STL ( 1 ) 

// ***** GaTas configurations 

// Maximum number of TCP clients that can connect to the server
#define GATAS_MAXIMUM_TCP_CLIENTS ( 4 )

// Default BUS frequency of SPI in MHZ
#define GATAS_SPI_DEFAULT_BUS_FREQUENCY ( 15 )

// Address field
// The address field starts with “$” followed by the talker ID and a sentence identifier. The used talker IDs are:
// * $P for GPS only solutions
// * $GL for GLONASS only solutions
// * $GA for GALILEO only solutions
// * $GN for multi GNSS solutions
// The used sentence identifiers are:
// * GGA – Global Positioning System Fix Data
// * VTG – Course over Ground and Ground Speed
// * GSA – GNSS DOP and Active Satellites
// * GSV – GNSS Satellites in View
// * RMC – Recommended Minimum Specific GNSS Data
// * ZDA – Time and Date
// Sentencs we never want to send over AirConnect
// #define GATAS_AIRCONNECT_DO_NOT_SEND  ""
#define GATAS_AIRCONNECT_DO_NOT_SEND  "$GPGLL,$GNRMC,$GNGGA,$GNGLL,$GNGSV,$GPGSV,$GLGSV,$GPGSA,$GNGSA,$GNVTG"

// Stat's collector antenna radial pattern divisions
#define GATAS_STATSCOLLECTOR_NUM_RADIALS ( 8 )

// K Factor to use for EMA Filter that ensures we filter values over a 1 second period reach minimum to maximum for 5 updates per second
#define GATAS_EMAFLOAT_K_FACTOR_5PS ( 1.9f )

// K Factor to use for EMA Filter that ensures we filter values over a 1 second period reach minimum to maximum for 2 updates per second
#define GATAS_EMAFLOAT_K_FACTOR_2PS ( 1.2f )

// Maximum radios that can be controlled
#define GATAS_MAX_RADIOS ( 2 ) 
// Maximum number of datasources per radio that can be handled
#define GATAS_MAX_SOURCE_PER_RADIO ( 3 )

// Maximum time the system will start scanning. If a scan result was found, then scanning will stop  aswell.
#define GATAS_WIFISERVICE_MAX_SCAN_TIME_MS 10000

// Maximum number of bluetooth connections
#define GATAS_MAX_BLUETOOTH_CONNECTIONS ( 3 )

// Signature for Flash configuration. When this signature changes, a compete new and fresh configuration will be loaded
// Make sure this value is the same as in gatas_default_config.json
#define GATAS_FLASH_SIGNATURE ( 250801 )

#define DISALLOW_COPY_AND_MOVE(Type)       \
    Type(const Type&) = delete;            \
    Type& operator=(const Type&) = delete; \
    Type(Type&&) = delete;                 \
    Type& operator=(Type&&) = delete;