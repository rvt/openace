#define PICO_CYW43_ARCH_DEFAULT_COUNTRY_CODE CYW43_COUNTRY_WORLDWIDE
#define CYW43_HOST_NAME "GATAS"

// https://github.com/raspberrypi/pico-sdk/issues/1443
#define PICO_MAX_SHARED_IRQ_HANDLERS 6

